!echo true

% List directory contents
ls() ? @os("linux") shell=sh:
    ls -la

ls() ? @os("macos") shell?=bash:
    ls -la

ls() ? @os("windows") shell?=pwsh:
    Get-ChildItem -Force

ls():
    ls -la

% Clean build artifacts
clean() ? @os("windows") shell?=pwsh:
    cargo clean
    Remove-Item -Recurse -Force ../dist -ErrorAction SilentlyContinue

clean():
    cargo clean
    rm -rf ../dist

% Build project
build() ? @os("windows") shell?=pwsh:
    cargo build --release

build():
    cargo build --release

% Run tests
test():
    cargo test

% Package the built binary
package() ? @os("windows") & build shell?=pwsh:
    New-Item -ItemType Directory -Force ../dist | Out-Null
    Copy-Item ../target/release/only.exe ../dist/only.exe -Force

package() & build:
    mkdir -p ../dist
    cp ../target/release/only ../dist/only

% Smoke-test the release binary
smoke() ? @os("windows") & build shell?=pwsh:
    ../target/release/only.exe --version

smoke() & build:
    ../target/release/only --version

% Run all tasks
all() & clean & build & test:
    echo "✅ All tasks completed"

% Build once, then package and smoke-test in parallel
release() & clean & build & (package, smoke):
    echo "✅ Release artifacts packaged and verified"
